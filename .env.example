# Copie este arquivo para ".env" (que fica fora do git) para rodar o sync localmente.
# Em producao, as mesmas chaves ficam como Secrets do GitHub Actions (nunca commitadas).

# Painel do Supabase > Project Settings > API
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=coloque-a-service-role-key-aqui

# Link "gid" de cada aba da planilha (Arquivo > Compartilhar > Qualquer pessoa com o link > Leitor)
# O numero depois de "gid=" na URL quando voce clica em cada aba.
SHEET_ID=1cPyArNy99U6sTJaHDNqUjRO2DN9wv-UJus-I9DKf-YE
SHEET_GID_COTACOES=0
SHEET_GID_COTACOES_HISTORICO=568641663
SHEET_GID_ACOES=SUBSTITUA_PELO_GID_DA_ABA_QUANTIDADE_DE_ACOES
SHEET_GID_SHARES_HISTORY=277174716
SHEET_GID_IR_LINKS=435768027

# Opcional: se o endpoint publico do FRED (fredgraph.csv) parar de funcionar,
# defina uma FRED_API_KEY (gratuita: https://fred.stlouisfed.org/docs/api/api_key.html)
# e o script usa a API oficial como alternativa.
FRED_API_KEY=
